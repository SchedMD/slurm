############################################################################
source ./globals

set job_id      0
set job_name    "jobname$test_id"
set name_read   ""

if {[get_config_param "PriorityType"] eq "priority/multifactor"} {
	skip "Not compatible with priority/multifactor"
}

proc cleanup {} {
	global job_id

	cancel_job $job_id
}

#
# Test setting job's name and get priority
#
set output [run_command_output -fail "$salloc -t1 --job-name=$job_name $bin_true"]
if {![regexp "Granted job allocation ($number)" $output - job_id]} {
	fail "Unable to get job_id from salloc"
}

set jobs [get_jobs]
set name [dict_getdef [dict_getdef $jobs $job_id {}] "JobName" ""]
subtest { $name == $job_name} "Verify that the job set the job name" "$name != $job_name"

set priority1 [dict_getdef [dict_getdef $jobs $job_id {}] "Priority" ""]
if { $priority1 == ""} {
	fail "Unable to get Priority from job $job_id"
}

#
# Test setting job's name and get priority
#
set output [run_command_output -fail "$salloc -t1 --nice=1000 $bin_true"]
if {![regexp "Granted job allocation ($number)" $output - job_id]} {
	fail "Unable to get job_id from salloc"
}

set jobs [get_jobs]
set priority2 [dict_getdef [dict_getdef $jobs $job_id {}] "Priority" ""]
if { $priority2 == ""} {
	fail "Unable to get Priority from job $job_id"
}
set delta_prio [expr $priority1 - $priority2]
subtest {$delta_prio >= 950} "Verify that the job processed the nice option" "$delta_prio < 950"
